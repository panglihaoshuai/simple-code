{
  "name": "simple-code",
  "version": "0.1.0",
  "opencodeVersion": ">=1.17.0 <2.0.0",
  "description": "Zero-config opencode plugin: agentmemory + CodeGraph + UA + 24 agent-skills + 5 LSP + 3 MCP",
  "entry": "./dist/index.js",
